{
  "schemaVersion": "0.1.0",
  "name": "知识库-文章剪藏",
  "behavior": "create",
  "noteContentFormat": "# {{title}}\n\n> [原文链接]({{url}})\n\n## 摘要\n\n{{content}}\n\n## 核心观点\n\n\n## 术语/概念\n\n\n## 疑问/待验证",
  "properties": [
    {
      "name": "type",
      "value": "article",
      "type": "text"
    },
    {
      "name": "source_url",
      "value": "{{url}}",
      "type": "text"
    },
    {
      "name": "author",
      "value": "{{author}}",
      "type": "text"
    },
    {
      "name": "published",
      "value": "{{published}}",
      "type": "date"
    },
    {
      "name": "ingested_at",
      "value": "{{date}}",
      "type": "date"
    },
    {
      "name": "tags",
      "value": "clippings",
      "type": "multitext"
    }
  ],
  "triggers": [],
  "noteNameFormat": "{{title}}",
  "path": "raw/articles"
}
